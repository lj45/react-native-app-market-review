{
  "compilerOptions": {
    "target": "ES6",
    "module": "CommonJS",
    "outDir": "./lib", // 编译输出到 lib 目录
    "rootDir": "./src", // 源码目录
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true, // 自动生成类型声明
    "declarationDir": "./lib"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "**/__tests__/*"]
}